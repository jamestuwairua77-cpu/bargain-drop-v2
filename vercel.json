{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "functions": {
    "api/sync-full.js": {
      "maxDuration": 300
    },
    "api/product-sync-webhook.js": {
      "maxDuration": 300
    }
  }
}